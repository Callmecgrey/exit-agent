# Required
NOXSERVER_API_BASE=https://api.noxguard.org
EXIT_SLUG=us-east-1
EXIT_AGENT_TOKEN=REPLACE_ME

WG_INTERFACE=wg0
WG_CONFIG_PATH=/etc/wireguard/wg0.conf
WG_PRIVATE_KEY_PATH=/etc/wireguard/privatekey

EXIT_WG_ADDRESS=10.200.0.1/24
EXIT_WG_LISTEN_PORT=51820

# Optional
POLL_INTERVAL_MS=15000
EXIT_AGENT_STATE_PATH=/var/lib/noxguard-exit-agent/state.json

# Optional WireGuard hooks (leave blank initially; add later once agent is healthy)
EXIT_WG_POST_UP=
EXIT_WG_POST_DOWN=
